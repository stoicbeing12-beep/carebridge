rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User Profiles
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Bookings
    match /databases/{database}/documents/bookings/{bookingId} {
      // Users can see their own bookings (as family or caregiver)
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid || 
        resource.data.caregiverId == request.auth.uid
      );
      // Families can create bookings
      allow create: if request.auth != null;
      // Both parties can update status
      allow update: if request.auth != null && (
        resource.data.userId == request.auth.uid || 
        resource.data.caregiverId == request.auth.uid
      );
    }
    
    // Care Logs
    match /databases/{database}/documents/careLogs/{logId} {
      // Caregivers can create logs
      allow create: if request.auth != null;
      // Families and the specific caregiver can read logs
      // Note: In production, you'd add a familyId field to logs for better filtering
      allow read: if request.auth != null; 
    }
    
    // Reviews
    match /databases/{database}/documents/reviews/{reviewId} {
      allow read: if true; // Public reviews
      allow create: if request.auth != null; // Authenticated users can review
    }
  }
}
